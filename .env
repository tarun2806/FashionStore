# ============================================================
# FashionStore Environment Configuration
# ============================================================
# NOTE: Replace placeholder values with actual credentials before deployment

# ============================================================
# Application Environment
# ============================================================
ENV=production
NODE_ENV=production
FASHIONSTORE_PROFILE=production

# ============================================================
# Backend Configuration
# ============================================================
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0

# ============================================================
# MySQL Configuration (Docker)
# ============================================================
MYSQL_ROOT_PASSWORD=Tarun@1605
MYSQL_DATABASE=fashionstore
MYSQL_USER=fashionstore
MYSQL_PASSWORD=Tarun@1605

# ============================================================
# Database Configuration
# ============================================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=fashionstore
DB_USER=fashionstore
DB_PASSWORD=Tarun@1605

# Alternative Database Configuration (for non-Docker environments)
# FASHIONSTORE_DB_URL=jdbc:mysql://localhost:3306/fashionstore?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# FASHIONSTORE_DB_USER=fashionstore
# FASHIONSTORE_DB_PASSWORD=Tarun@1605

# ============================================================
# Redis Configuration
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================
# Security Configuration
# ============================================================
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true

# ============================================================
# Payment Configuration
# ============================================================
# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_API_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# QA Test Mode - Set to true to disable rate limiting for testing
QA_MODE=true

# ============================================================
# CORS Configuration
# ============================================================
# Development: http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Staging: https://staging.fashionstore.com,https://admin-staging.fashionstore.com
# Production: https://www.fashionstore.com,https://admin.fashionstore.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# CSP Configuration
# ============================================================
# Development: http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Staging: https://staging.fashionstore.com,https://admin-staging.fashionstore.com
# Production: https://www.fashionstore.com,https://admin.fashionstore.com
CSP_ALLOWED_FRAME_ANCESTORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# Email Configuration
# ============================================================
EMAIL_ENABLED=false
SMTP_HOST=smtp.email-provider.com
SMTP_PORT=587
SMTP_USER=fashionstore@email-provider.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@fashionstore.com

# ============================================================
# Admin Frontend Configuration
# ============================================================
VITE_BACKEND_TARGET=http://localhost:8080
VITE_API_BASE=http://localhost:8080/api/admin

# ============================================================
# Logging Configuration
# ============================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=TEXT

# ============================================================
# Session Configuration
# ============================================================
SESSION_TIMEOUT=1800

# ============================================================
# Monitoring Configuration
# ============================================================
ENABLE_METRICS=false
METRICS_PORT=9090

# ============================================================
# SSL/TLS Configuration
# ============================================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ============================================================
# Backup Configuration
# ============================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ============================================================
# CDN Configuration
# ============================================================
CDN_ENABLED=false
CDN_DOMAIN=cdn.fashionstore.com

